                SegmentedButton {
                    items: [
                        { text: "Day" },
                        { text: "Week" },
                        { text: "Month" },
                        { text: "Year" },
                    ];
                    current_index <=> root.segmented-index;
                }

                HorizontalDivider { }

                // lists
                SectionHeader {
                    title: "Lists";
                }

                OutlinedCard {
                    width: 500px;

                    VerticalLayout {
                        ListTile {
                            text: "First Item";
                            supporting_text: "Supporting text for the first item";
                            avatar_background: MaterialPalette.primary;

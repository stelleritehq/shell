                                height: 60px;
                                level: 5;
                                border_radius: 12px;
                                background: MaterialPalette.surface;

                                MaterialText {
                                    text: "L5";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    style: MaterialTypography.label_medium;
                                }

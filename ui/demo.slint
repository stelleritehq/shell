import { MaterialScheme, MaterialSchemes } from "@material";
import { ToolTip } from "@material";

// a section header; for every section (to label)
component SectionHeader {
    in property <string> title;

    HorizontalLayout {
        padding-top: 24px;
        padding-bottom: 8px;

        MaterialText {
            text: root.title;
            style: MaterialTypography.title_large;
            color: MaterialPalette.primary;
        }
    }
}

component SubSectionHeader {
    in property <string> title;

    HorizontalLayout {
        padding-top: 12px;
        padding-bottom: 4px;

        MaterialText {
            text: root.title;
            style: MaterialTypography.title_small;
            color: MaterialPalette.on_surface_variant;
        }
    }
}

// to display palette colors, color swatch
component ColorSwatch {
    in property <string> label;
    in property <color> swatch_color;
    in property <color> text_color: MaterialPalette.on_surface;

    width: 80px;
    height: 52px;

    Rectangle {
        width: 100%;
        height: 100%;
        background: root.swatch_color;
        border-radius: MaterialStyleMetrics.border_radius_8;

        MaterialText {
            x: 4px;
            y: parent.height - self.height - 4px;
            text: root.label;
            style: MaterialTypography.label_small;
            color: root.text_color;
        }
    }
}

// main demo window to keep things in
export component App inherits Window {
    title: "MD3 Component Library";
    width: 900px;
    height: 720px;
    background: MaterialPalette.background;


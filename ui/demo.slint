                // dividers
                SectionHeader {
                    title: "Dividers";
                }

                MaterialText {
                    text: "Horizontal dividers separate content sections (of COURSE):";
                    style: MaterialTypography.body_medium;
                    color: MaterialPalette.on_surface_variant;
                }

                HorizontalDivider { }

                HorizontalLayout {
                    spacing: 16px;
                    height: 60px;

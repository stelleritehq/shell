                }

                HorizontalDivider { }

                // tabs and segmented buttons
                SectionHeader {
                    title: "Tabs & *Segmented Button";
                }

                SubSectionHeader {
                    title: "Primary Tab Bar";
                }

                TabBar {
                    items: root.tab-items;
                    current_index <=> root.tab-index;
                    width: 500px;
                }

                SubSectionHeader {
                    title: "Secondary Tab Bar";
                }

                SecondaryTabBar {
                    items: root.tab-items;
                    current_index <=> root.secondary-tab-index;
                    width: 500px;
                }

                SubSectionHeader {
                    title: "Segmented Button";

                    MaterialText {
                        text: "Left";
                        style: MaterialTypography.body_medium;
                        vertical-alignment: center;
                    }

                    VerticalDivider { }

                    MaterialText {
                        text: "Middle";
                        style: MaterialTypography.body_medium;
                        vertical-alignment: center;
                    }

                    VerticalDivider { }

                    MaterialText {
                        text: "Right";
                        style: MaterialTypography.body_medium;
                        vertical-alignment: center;
                    }
                }

                HorizontalDivider { }

                // animations refs
                SectionHeader {
                    title: "Animation Tokens";
                }

                MaterialText {
                    text: "MaterialAnimations (Slint Native animations, there *might be a vex animation adapter)";
                    style: MaterialTypography.body_medium;
                    color: MaterialPalette.on_surface_variant;
                }

                OutlinedCard {
                    width: 600px;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 4px;

                        MaterialText {
                            text: "emphasized_duration: 500ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "emphasized_decelerate_duration: 400ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "emphasized_accelerate_duration: 200ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "standard_decelerate_duration: 250ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "standard_accelerate_duration: 200ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "standard_fast_duration: 150ms";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "ripple_duration: 2s";
                            style: MaterialTypography.body_small;
                        }

                        MaterialText {
                            text: "opacity_duration: 250ms";
                            style: MaterialTypography.body_small;
                        }
                    }
                }

                HorizontalDivider { }

                // metrics reference
                SectionHeader {
                    title: "Style Metrics";
                }

                MaterialText {
                    text: "MaterialStyleMetrics: sizes, padding, spacing, border radiuses";
                    style: MaterialTypography.body_medium;
                    color: MaterialPalette.on_surface_variant;
                }

                HorizontalLayout {
                    spacing: 16px;

                    OutlinedCard {
                        width: 180px;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 2px;
                            MaterialText {
                                text: "Sizes";
                                style: MaterialTypography.title_small;
                                color: MaterialPalette.primary;
                            }

                            MaterialText {
                                text: "size_4: 4px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "size_8: 8px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "size_16: 16px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "size_24: 24px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "size_40: 40px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "size_56: 56px";
                                style: MaterialTypography.body_small;
                            }
                        }
                    }

                    OutlinedCard {
                        width: 180px;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 2px;
                            MaterialText {
                                text: "Padding";
                                style: MaterialTypography.title_small;
                                color: MaterialPalette.primary;
                            }

                            MaterialText {
                                text: "padding_4: 4px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "padding_8: 8px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "padding_12: 12px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "padding_16: 16px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "padding_24: 24px";
                                style: MaterialTypography.body_small;
                            }
                        }
                    }

                    OutlinedCard {
                        width: 180px;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 2px;
                            MaterialText {
                                text: "Border Radius";
                                style: MaterialTypography.title_small;
                                color: MaterialPalette.primary;
                            }

                            MaterialText {
                                text: "radius_2: 2px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "radius_4: 4px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "radius_8: 8px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "radius_12: 12px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "radius_16: 16px";
                                style: MaterialTypography.body_small;
                            }

                            MaterialText {
                                text: "radius_28: 28px";
                                style: MaterialTypography.body_small;
                            }
                        }
                    }
                }

                // bottom spacer
                Rectangle {
                    height: 32px;
                }
            }
        }

        // navigation bar (bottom)
        NavigationBar {
            items: root.nav-items;
            current_index <=> root.nav-index;
        }
    }

    // snackBar (popup)
    snack-bar := SnackBar {
        text: "This is a snackbar message (here are some snacks)";
        action_text: "Undo";
        has_close_button: true;
    }

    // dialog
    demo-dialog := Dialog {
        title: "Dialog Title";
        actions: ["Cancel"];
        default_action_text: "007";

        MaterialText {
            text: "This is a Material Design 3 dialog with actions.";
            style: MaterialTypography.body_medium;
            color: MaterialPalette.on_surface;
            wrap: word-wrap;
        }
    }
}


// this is technically docs, but its practical (as it is compiled into code)

    in-out property <int> nav-index: 0;
    in-out property <int> tab-index: 0;
    in-out property <int> secondary-tab-index: 0;
    in-out property <int> segmented-index: 0;
    in-out property <int> radio-selected: 0;
    in-out property <float> slider-value: 40;
    in-out property <float> progress-value: 0.65;
    in-out property <bool> switch-on: true;
    in-out property <bool> switch-off: false;
    in-out property <string> text-field-value: "";
